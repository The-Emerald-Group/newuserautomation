<Window x:Class="NewUserAutomation.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NewUserAutomation.App"
        mc:Ignorable="d"
        Title="New User Automation" Height="620" Width="1000" Background="#12161C">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DCE6F2" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A3442" />
            <Setter Property="Foreground" Value="#EAF2FC" />
            <Setter Property="BorderBrush" Value="#3B4B5E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,4" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#344356" />
                    <Setter Property="BorderBrush" Value="#4E627A" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#243140" />
                    <Setter Property="BorderBrush" Value="#5B789C" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="1" />
                    <Setter Property="Foreground" Value="#D6E0EE" />
                    <Setter Property="Background" Value="#3A4350" />
                    <Setter Property="BorderBrush" Value="#576579" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#10161D" />
            <Setter Property="Foreground" Value="#EAF2FC" />
            <Setter Property="BorderBrush" Value="#334155" />
            <Setter Property="CaretBrush" Value="#EAF2FC" />
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#0E141B" />
                    <Setter Property="Foreground" Value="#D3DEEA" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#10161D" />
            <Setter Property="Foreground" Value="#EAF2FC" />
            <Setter Property="BorderBrush" Value="#334155" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#10161D" />
            <Setter Property="Foreground" Value="#EAF2FC" />
            <Setter Property="Padding" Value="6,2" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#1E2A38" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#2B6CB0" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#10161D" />
            <Setter Property="Foreground" Value="#EAF2FC" />
            <Setter Property="BorderBrush" Value="#334155" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#EAF2FC" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1E2A38" />
                    <Setter Property="Foreground" Value="#FFFFFF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#172435" CornerRadius="10" Padding="16" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Text="New User Automation" />
                <TextBlock Margin="0,6,0,0" Foreground="#C8D6E8" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#1A2028" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid Visibility="{Binding IsSignInStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel HorizontalAlignment="Stretch">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#8BB9FF" Text="Step 1: Select Customer and Sign In" />
                        <TextBlock Margin="0,6,0,8" Foreground="#C3CFDD" Text="One-app flow: 1) Select/create customer, 2) Enter tenant + site details, 3) Set Up Customer App (one-time), 4) Save Customer, 5) Connect All, 6) Continue." TextWrapping="Wrap" />
                        <Grid Margin="0,0,0,4" HorizontalAlignment="Left">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="230" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Margin="0,8,0,0" FontWeight="SemiBold" Text="Customer" />
                            <ComboBox Grid.Column="1" Height="30" Margin="8,0,0,0"
                                      Background="#F3F6FB"
                                      Foreground="#0F172A"
                                      BorderBrush="#4B607A"
                                      TextElement.Foreground="#0F172A"
                                      ItemsSource="{Binding Customers}"
                                      SelectedItem="{Binding SelectedCustomer, Mode=TwoWay}"
                                      DisplayMemberPath="Name">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="#F3F6FB" />
                                        <Setter Property="Foreground" Value="#0F172A" />
                                        <Setter Property="Padding" Value="6,2" />
                                        <Style.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter Property="Background" Value="#DBE7F5" />
                                                <Setter Property="Foreground" Value="#0B1220" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#C8DBEF" />
                                                <Setter Property="Foreground" Value="#0B1220" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                            <Button Grid.Column="2" Height="30" Margin="8,0,0,0" Content="New" Command="{Binding NewCustomerCommand}" />
                            <Button Grid.Column="3" Height="30" Margin="8,0,0,0" Content="Delete" Command="{Binding DeleteCustomerCommand}" />
                            <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0">
                                <Button Width="108" Height="30" Content="{Binding CustomerEditButtonText}" Command="{Binding EditCustomerCommand}" />
                                <Button Width="104" Height="30" Margin="6,0,0,0" Content="Save Customer" Command="{Binding SaveCustomerCommand}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Margin="0,0,0,8" Foreground="#A9B7C9" FontStyle="Italic" Text="{Binding CustomerEditStatus}" />
                        <Grid Margin="0,0,0,10">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCustomerEditLocked}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="340" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="340" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,6,8,0" FontWeight="SemiBold" Text="Customer Name" />
                            <TextBox Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,16,0"
                                     IsReadOnly="{Binding IsCustomerEditLocked}"
                                     Text="{Binding CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="0,6,8,0" FontWeight="SemiBold" Text="Tenant Domain" />
                            <TextBox Grid.Row="0" Grid.Column="3" Height="30"
                                     IsReadOnly="{Binding IsCustomerEditLocked}"
                                     Text="{Binding TenantDomain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,8,0" FontWeight="SemiBold" Text="SharePoint Site URL" />
                            <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Height="30" Margin="0,4,0,0"
                                     IsReadOnly="{Binding IsCustomerEditLocked}"
                                     Text="{Binding SelectedSharePointSiteUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <Grid Margin="0,0,0,10" HorizontalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,0" Orientation="Horizontal">
                                <Button Width="220" Height="34" Background="#2F6CB3" Foreground="White" BorderBrush="#2F6CB3" Content="1) Set Up Customer App (One-Time)" Command="{Binding SetupCustomerAppCommand}" />
                                <Button Width="26" Height="34" Margin="6,0,0,0" Content="?" ToolTip="One-app setup help" Command="{Binding ShowExchangeSetupHelpCommand}" />
                                <Button Width="130" Height="34" Margin="6,0,0,0" Content="2) Save Customer" Command="{Binding SaveCustomerCommand}" />
                                <Button Width="160" Height="34" Margin="6,0,0,0" Background="#2F6CB3" Foreground="White" BorderBrush="#2F6CB3" Content="3) Connect All (One App)" Command="{Binding QuickConnectCommand}" />
                            </WrapPanel>

                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       Foreground="#C3CFDD"
                                       Text="One App: Run one-time setup once per customer, then use Connect All for daily use."
                                       TextWrapping="Wrap" />

                            <TextBlock Grid.Row="2" Margin="0,12,0,0" FontWeight="SemiBold" Text="Connection status" />
                            <Grid Grid.Row="3" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#0F1722" BorderBrush="#334155" BorderThickness="1" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="190" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="#C3CFDD" Text="Graph" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GraphStatus}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,10,0" FontWeight="SemiBold" Foreground="#C3CFDD" Text="Exchange" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0" Text="{Binding ExchangeStatus}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,10,0" FontWeight="SemiBold" Foreground="#C3CFDD" Text="SharePoint (PnP)" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" Text="{Binding PnPStatus}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </Grid>

                        </Grid>

                        <Border Margin="0,0,0,10"
                                Padding="10,8"
                                MinHeight="46"
                                Background="#0F1722"
                                BorderBrush="#334155"
                                BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAuthBusy}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Foreground="#C3CFDD" FontWeight="SemiBold" Text="{Binding SignInPhaseMessage}" />
                                <ProgressBar Margin="0,6,0,0" Height="10" IsIndeterminate="True" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Width="210" Height="34" Content="Continue to Upload" Command="{Binding ContinueToUploadCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding IsUploadStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#8BB9FF" Text="Step 2: Upload New Employee Form" />
                        <TextBlock Margin="0,8,0,16" Foreground="#C3CFDD" Text="Choose the DOCX form. Parser now reads your employee form template directly." TextWrapping="Wrap" />
                        <TextBlock FontWeight="SemiBold" Text="Selected file" />
                        <TextBox Margin="0,6,0,12" IsReadOnly="True" Text="{Binding SelectedFilePath}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Width="140" Height="34" Content="Browse File..." Click="OnBrowseFileClick" />
                            <Button Width="200" Height="34" Margin="12,0,0,0" Content="Continue to Review" Command="{Binding ContinueToReviewCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding IsReviewStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Foreground="#8BB9FF" Text="Step 3: Review and Dry Run" />
                    <TextBlock Grid.Row="1" Margin="0,6,0,4" Foreground="#C3CFDD" Text="Decision point: review each planned change and run preflight. Proceed only when all checks are PASS." TextWrapping="Wrap" />

                    <Grid Grid.Row="2" Margin="0,12,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#10161D" BorderBrush="#334155" BorderThickness="1" Padding="10">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Edit parsed form values before preflight" />
                                <TextBlock Margin="0,4,0,8" Foreground="#C3CFDD" Text="Correct spelling mistakes or adjust values, then click Refresh Dry Run." TextWrapping="Wrap" />
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="First Name" />
                                        <TextBox Height="28" Text="{Binding EditFirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Last Name" />
                                        <TextBox Height="28" Text="{Binding EditLastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="Display Name" />
                                        <TextBox Height="28" Text="{Binding EditDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Preferred Username / UPN" />
                                        <TextBox Height="28" Text="{Binding EditPreferredUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="Temporary Password" />
                                        <TextBox Height="28" Text="{Binding EditTemporaryPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Job Title" />
                                        <TextBox Height="28" Text="{Binding EditJobTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="Primary Email" />
                                        <TextBox Height="28" Text="{Binding EditPrimaryEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Secondary Email" />
                                        <TextBox Height="28" Text="{Binding EditSecondaryEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="Licenses (; separated)" />
                                        <TextBox Height="28" Text="{Binding EditLicenseSkus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Groups (; separated)" />
                                        <TextBox Height="28" Text="{Binding EditGroupAccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="Shared Mailboxes (; separated)" />
                                        <TextBox Height="28" Text="{Binding EditSharedMailboxAccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="SharePoint Access (; separated)" />
                                        <TextBox Height="28" Text="{Binding EditSharePointAccess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="Personal Folder Additional Users (; separated)" />
                                        <TextBox Height="28" Text="{Binding EditPersonalSharePointAdditionalMembers, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,12,6">
                                        <TextBlock Text="Approved By" />
                                        <TextBox Height="28" Text="{Binding EditRequestApprovedBy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,0,6">
                                        <TextBlock Text="Special Requirements" />
                                        <TextBox Height="28" Text="{Binding EditSpecialRequirements, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </UniformGrid>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <Button Width="170" Height="32" Content="Refresh Dry Run" Command="{Binding ApplyReviewEditsCommand}" />
                                </StackPanel>
                                <Border Margin="0,8,0,0" Padding="8" Background="#0F1722" BorderBrush="#334155" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold" Text="Resolve personal-folder users (first-name candidates)" />
                                        <TextBlock Margin="0,2,0,6" Foreground="#C3CFDD" Text="Preflight finds candidate accounts by first name. Confirm the correct account for each user here, then rerun preflight." TextWrapping="Wrap" />
                                        <ItemsControl ItemsSource="{Binding PersonalFolderUserMatchChoices}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="250" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#DCE6F2"
                                                                   Text="{Binding SourceIdentity}" />
                                                        <ComboBox Grid.Column="1"
                                                                  Height="28"
                                                                  Background="#F3F6FB"
                                                                  Foreground="#0F172A"
                                                                  BorderBrush="#4B607A"
                                                                  TextElement.Foreground="#0F172A"
                                                                  ItemsSource="{Binding MatchOptions}"
                                                                  SelectedItem="{Binding SelectedPrincipal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                            <ComboBox.ItemContainerStyle>
                                                                <Style TargetType="ComboBoxItem">
                                                                    <Setter Property="Background" Value="#F3F6FB" />
                                                                    <Setter Property="Foreground" Value="#0F172A" />
                                                                    <Setter Property="Padding" Value="6,2" />
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsHighlighted" Value="True">
                                                                            <Setter Property="Background" Value="#DBE7F5" />
                                                                            <Setter Property="Foreground" Value="#0B1220" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsSelected" Value="True">
                                                                            <Setter Property="Background" Value="#C8DBEF" />
                                                                            <Setter Property="Foreground" Value="#0B1220" />
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ComboBox.ItemContainerStyle>
                                                        </ComboBox>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock Grid.Row="1" Margin="0,10,0,8" FontWeight="SemiBold" Text="Dry run plan" />
                        <ListBox Grid.Row="2"
                                 MaxHeight="220"
                                 Background="#10161D"
                                 BorderBrush="#334155"
                                 ItemsSource="{Binding DryRunLines}"
                                 PreviewMouseWheel="OnInnerListBoxPreviewMouseWheel" />

                        <Grid Grid.Row="3" Margin="0,10,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" FontWeight="SemiBold" VerticalAlignment="Center" Text="Preflight checklist" />
                            <Button Grid.Column="1" Height="28" Padding="10,0" Content="{Binding ParserDiagnosticsToggleText}" Command="{Binding ToggleParserDiagnosticsCommand}" />
                        </Grid>
                        <ListBox Grid.Row="4"
                                 MaxHeight="280"
                                 Background="#10161D"
                                 BorderBrush="#334155"
                                 ItemsSource="{Binding PreflightChecks}"
                                 PreviewMouseWheel="OnInnerListBoxPreviewMouseWheel">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" FontWeight="Bold" Text="{Binding Status}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#3A4A5F" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="PASS">
                                                            <Setter Property="Foreground" Value="#7CD992" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="FAIL">
                                                            <Setter Property="Foreground" Value="#F8BBD0" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="INFO">
                                                            <Setter Property="Foreground" Value="#7CB8FF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Check}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2" Margin="8,0,0,0" Text="{Binding Detail}" TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#C3CFDD" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="PASS">
                                                            <Setter Property="Foreground" Value="#7CD992" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="FAIL">
                                                            <Setter Property="Foreground" Value="#F8BBD0" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="INFO">
                                                            <Setter Property="Foreground" Value="#7CB8FF" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <StackPanel Grid.Row="3">
                        <TextBlock FontWeight="SemiBold" Text="Preflight Result" />
                        <TextBlock Margin="0,4,0,10" Text="{Binding PreflightResult}" TextWrapping="Wrap" />
                        <Border Margin="0,0,0,10"
                                Padding="10,8"
                                Background="#0F1722"
                                BorderBrush="#334155"
                                BorderThickness="1"
                                Visibility="{Binding IsAuthBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Foreground="#C3CFDD" FontWeight="SemiBold" Text="{Binding SignInPhaseMessage}" />
                                <ProgressBar Margin="0,6,0,0" Height="8" IsIndeterminate="True" />
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal">
                            <Button Width="140" Height="34" Content="Back to Upload" Command="{Binding BackToUploadCommand}" />
                            <Button Width="140" Height="34" Margin="12,0,0,0" Background="#2F6CB3" Foreground="White" BorderBrush="#2F6CB3" Content="Run Preflight" Command="{Binding RunPreflightCommand}" />
                            <Button Width="170" Height="34" Margin="12,0,0,0" Content="Continue to Live Run" Command="{Binding ContinueToLiveRunCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding IsLiveRunStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Foreground="#8BB9FF" Text="Step 4: Safe Live Run" />
                    <Border Grid.Row="1" Margin="0,12,0,12" Background="#10161D" BorderBrush="#334155" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="Safe live run progress" />
                            <TextBlock Margin="0,6,0,6" Foreground="#C3CFDD" Text="{Binding LiveRunStatus}" TextWrapping="Wrap" />
                            <TextBlock Margin="0,0,0,4" Foreground="#A9B7C9" Text="{Binding LiveRunProgressText}" />
                            <ProgressBar Margin="0,0,0,8" Height="10" Minimum="0" Maximum="100" Value="{Binding LiveRunProgressPercent, Mode=OneWay}" />
                            <TextBlock Margin="0,0,0,8" Foreground="#A9B7C9" Text="{Binding LiveRunLogPath}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Width="160" Height="34" Content="Start Safe Live Run" Command="{Binding StartSafeLiveRunCommand}" />
                                <Button Width="160" Height="34" Margin="12,0,0,0" Background="#2F6CB3" Foreground="White" BorderBrush="#2F6CB3" Content="Run Next Live Step" Command="{Binding ExecuteNextLiveStepCommand}" />
                                <Button Width="190" Height="34" Margin="12,0,0,0" Content="Run All Remaining Steps" Command="{Binding ExecuteAllLiveStepsCommand}" />
                                <Button Width="130" Height="34" Margin="12,0,0,0" Content="Skip Current Step" Command="{Binding SkipLiveStepCommand}" />
                                <Button Width="120" Height="34" Margin="12,0,0,0" Content="Reset Live Run" Command="{Binding ResetLiveRunCommand}" />
                                <Button Width="130" Height="34" Margin="12,0,0,0" Content="Finish Live Run" Command="{Binding FinishLiveRunCommand}" />
                            </StackPanel>
                            <ListBox MaxHeight="360"
                                     Background="#10161D"
                                     BorderBrush="#334155"
                                     ItemsSource="{Binding LiveRunSteps}"
                                     PreviewMouseWheel="OnLiveRunListPreviewMouseWheel">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="320" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" FontWeight="Bold" Text="{Binding Status}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#C3CFDD" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                <Setter Property="Foreground" Value="#7CD992" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                <Setter Property="Foreground" Value="#F8BBD0" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                                <Setter Property="Foreground" Value="#FFD27A" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="InProgress">
                                                                <Setter Property="Foreground" Value="#7CB8FF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Description}" TextWrapping="Wrap" />
                                            <TextBlock Grid.Column="2" Margin="8,0,0,0" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <Button Width="150" Height="34" Content="Back to Review" Command="{Binding BackToReviewCommand}" />
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding IsSummaryStep, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Foreground="#8BB9FF" Text="Step 5: Live Run Summary" />
                    <TextBlock Grid.Row="1" Margin="0,8,0,10" Foreground="#C3CFDD" Text="{Binding LiveRunSummaryHeadline}" TextWrapping="Wrap" />
                    <ListBox Grid.Row="2"
                             Background="#10161D"
                             BorderBrush="#334155"
                             ItemsSource="{Binding LiveRunSummarySteps}"
                             PreviewMouseWheel="OnInnerListBoxPreviewMouseWheel">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="320" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontWeight="Bold" Text="{Binding Status}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#C3CFDD" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#7CD992" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Skipped">
                                                        <Setter Property="Foreground" Value="#FFD27A" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Margin="8,0,0,0" Text="{Binding Description}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="2" Margin="8,0,0,0" Text="{Binding Detail}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="3" Margin="0,10,0,0" Orientation="Horizontal">
                        <Button Width="150" Height="34" Content="Back to Live Run" Command="{Binding BackToLiveRunCommand}" />
                    </StackPanel>
                </Grid>
            </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center" Foreground="#A9B7C9" Text="Step 3 validates and preflights. Step 4 executes live actions with checkpoints." />
            <Button Grid.Column="1" Width="130" Height="30" Margin="10,0,0,0" Content="Back to Start" Command="{Binding BackToStartCommand}" />
            <Button Grid.Column="2" Width="110" Height="30" Margin="10,0,0,0" Content="Close App" Command="{Binding CloseApplicationCommand}" />
        </Grid>
    </Grid>
</Window>
